# =============================================================================
# MediCast — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your secrets before running:
#   cp src/deploy/.env.example src/deploy/.env
#   docker compose -f src/deploy/docker-compose.yml up -d
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_to_a_secure_password

# ── MinIO (S3-Compatible Storage) ────────────────────────────────────────────
MINIO_ACCESS_KEY=medicast_admin
MINIO_SECRET_KEY=change_me_to_a_secure_minio_secret

# ── API Key (optional; for simple auth) ──────────────────────────────────────
API_KEY=change_me_to_an_api_key

# ── JWT Secret (for email/password auth) ────────────────────────────────────
JWT_SECRET=change_me_to_a_random_secret_string

# ── Inference Provider ───────────────────────────────────────────────────────
# Unset / empty      → Mock mode (no GPU needed, procedurally generated results)
# INFERENCE_PROVIDER=vllm   → Real ROCm inference via vLLM
# INFERENCE_PROVIDER=ollama → Real ROCm inference via Ollama
INFERENCE_PROVIDER=
INFERENCE_ENDPOINT=
INFERENCE_API_KEY=

# ── Model Selection ──────────────────────────────────────────────────────────
# Vision model (used by agents 1-4: Anatomy, Safety, Phase, Education)
MODEL_VISION=Qwen/Qwen2-VL-7B-Instruct

# Text model (used by Arbiter agent for cross-agent synthesis)
MODEL_TEXT=NousResearch/Meta-Llama-3.3-70B-Instruct